---
import Layout from '../layouts/Layout.astro';
import { Hero } from '../components/Hero';
import { About } from '../components/About';
import { Skills } from '../components/Skills';
import { Projects } from '../components/Projects';
import { Experience } from '../components/Experience';
import { Contact } from '../components/Contact';
import { Navbar } from '../components/Navbar';
import { Footer } from '../components/Footer';
import '../styles/global.css';

const title = "Dennis Jean Thompson — Full-Stack Developer";
const description = "Full-Stack Developer | Building payroll systems, microservices & AI tools that ship";
---
<Layout title={title} description={description}>
  <Navbar client:load />
  <main class="bg-zinc-950 text-zinc-300 font-sans selection:bg-indigo-500/30 overflow-hidden">
    <Hero client:load />
    <Projects />
    <About />
    <Skills />
    <Experience />
    <Contact />
  </main>
  <Footer />
</Layout>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((e) => {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
      }
    });
  }, { threshold: 0.15 });
  
  document.querySelectorAll('.animate-fade-up').forEach((el) => observer.observe(el));
</script>
